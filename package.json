    "depcruise": "depcruise src",
    "format": "prettier --log-level warn --write .",
    "vitest": "vitest run",
    "vitest:watch": "vitest",
    "test": "pnpm run typecheck && pnpm run format && pnpm run lint && pnpm run depcruise && pnpm run vitest && pnpm run build",
